generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  waNumber  String?  @unique
  role      String   @default("owner")
  createdAt DateTime @default(now())

  tasks     Task[]
}

model Agent {
  id           String   @id @default(uuid())
  name         String   @unique
  systemPrompt String
  color        String?
  status       String   @default("idle")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tasks        Task[]
  memories     Memory[]
  skills       Skill[]
}

model Task {
  id         String   @id @default(uuid())
  agentId    String
  userId     String?
  inputText  String
  outputText String?
  status     String   @default("pending")
  source     String   @default("manual")

  runtimeProviderId   String?
  runtimeProviderName String?
  runtimeProviderType String?
  runtimeModel        String?
  runtimeMode         String?
  runtimeResolvedFrom String?

  governanceAllowed              Boolean?
  governanceReason               String?
  governanceConfidence           String?
  governanceMatchedAllowedJson   String?
  governanceMatchedDeniedJson    String?
  governanceMatchedSoftJson      String?
  governanceMatchedSmallTalkJson String?
  governanceSuggestedAgentsJson  String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  agent      Agent    @relation(fields: [agentId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])
}

model Memory {
  id        String   @id @default(uuid())
  agentId   String
  content   String
  type      String   @default("general")

  scope                 String  @default("agent")
  ownerAgentName         String?
  allowedAgentsJson      String  @default("[]")
  linkedSkillNamesJson   String  @default("[]")
  runtimeInjectable      Boolean @default(false)
  ragEnabled             Boolean @default(false)
  sensitivityLevel       String  @default("normal")
  sourceType             String  @default("manual")
  sourceRef              String?

  createdAt DateTime @default(now())

  agent     Agent    @relation(fields: [agentId], references: [id])
}

model Skill {
  id          String   @id @default(uuid())
  agentId     String
  name        String
  description String?
  filePath    String?
  content     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent       Agent    @relation(fields: [agentId], references: [id])
}

model LlmProvider {
  id              String   @id @default(cuid())
  name            String   @unique
  type            String
  baseUrl         String?
  apiKeyEncrypted String?
  apiKeyPreview   String?
  defaultModel    String   @default("auto")
  enabled         Boolean  @default(true)

  capabilitiesJson String @default("[]")
  modelAliasesJson String @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentCapabilityContract {
  id                  String   @id @default(cuid())
  agentName           String   @unique
  displayName         String
  role                String
  description         String
  strictBoundary      Boolean  @default(true)
  unknownIntentPolicy String   @default("clarify_or_refuse")

  allowedDomainsJson        String @default("[]")
  deniedDomainsJson         String @default("[]")
  allowedKeywordsJson       String @default("[]")
  deniedKeywordsJson        String @default("[]")
  softAllowedKeywordsJson   String @default("[]")
  safeSmallTalkKeywordsJson String @default("[]")
  primarySkillsJson         String @default("[]")
  fallbackAgentsJson        String @default("[]")

  refusalStyle         String @default("polite_redirect")
  refusalMessage       String
  unknownIntentMessage String

  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}